# ─── Mode ────────────────────────────────────────────────────────────────────
# Start in simulation mode — no real money at risk
BOT_MODE=SIMULATION

# ─── Polymarket Credentials (required for LIVE mode) ─────────────────────────
# Get these from: https://polymarket.com/settings → API Keys
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# Your Polygon wallet private key (hex, with 0x prefix)
# NEVER commit this to git. Use a dedicated trading wallet.
POLY_PRIVATE_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/claudequant
REDIS_URL=redis://localhost:6379/0

# ─── Strategy Parameters ─────────────────────────────────────────────────────
# Kelly fraction: 0.25 = quarter-Kelly (conservative)
KELLY_FRACTION=0.25

# Minimum edge to enter a trade (2% misprice)
MIN_EDGE_PERCENT=0.02

# Minimum confidence score [0..1]
MIN_EDGE_CONFIDENCE=0.60

# Max position size as % of bankroll
MAX_POSITION_PCT=0.05

# Max daily drawdown before halting
MAX_DAILY_DRAWDOWN_PCT=0.05

# Starting bankroll (USDC)
STARTING_BANKROLL=10000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-char-secret

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
