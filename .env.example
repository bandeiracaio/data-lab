# Trading mode: paper or live
TRADE_MODE=paper

# Alpaca paper trading credentials (https://app.alpaca.markets → Paper Trading)
ALPACA_PAPER_KEY=your_paper_key_here
ALPACA_PAPER_SECRET=your_paper_secret_here

# Alpaca live trading credentials (only needed if TRADE_MODE=live)
ALPACA_KEY=your_live_key_here
ALPACA_SECRET=your_live_secret_here
